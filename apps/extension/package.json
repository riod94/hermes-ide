{
  "name": "hermes-ide",
  "displayName": "Hermes IDE",
  "publisher": "nusawork",
  "description": "Agentic Browser IDE extension for Hermes AI — Chat with AI, review code diffs, and accept/reject proposed changes directly in your editor.",
  "version": "0.9.5",
  "license": "UNLICENSED",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/riod94/hermes-ide"
  },
  "homepage": "https://github.com/riod94/hermes-ide#readme",
  "bugs": {
    "url": "https://github.com/riod94/hermes-ide/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Chat",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "hermes",
    "mcp",
    "agentic",
    "diff",
    "code-review",
    "chat",
    "copilot",
    "nusawork"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hermes-sidebar",
          "title": "Hermes IDE",
          "icon": "$(zap)"
        }
      ]
    },
    "views": {
      "hermes-sidebar": [
        {
          "type": "webview",
          "id": "hermes.chatView",
          "name": "Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "commands": [
      {
        "command": "hermes.focus",
        "title": "Hermes: Focus Chat",
        "category": "Hermes"
      },
      {
        "command": "hermes.resolveDiff",
        "title": "Hermes: Resolve Diff (Accept/Reject)",
        "category": "Hermes"
      },
      {
        "command": "hermes.showDiffControls",
        "title": "Hermes: Show Diff Controls",
        "category": "Hermes"
      },
      {
        "command": "hermes.addToChat",
        "title": "Hermes: Add Selection to Chat",
        "category": "Hermes"
      }
    ],
    "keybindings": [
      {
        "command": "hermes.addToChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus || terminalFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "hermes.addToChat",
          "when": "editorHasSelection",
          "group": "hermes@1"
        }
      ],
      "terminal/context": [
        {
          "command": "hermes.addToChat",
          "group": "hermes@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run esbuild-base --minify",
    "compile": "bun run esbuild-base --sourcemap",
    "watch": "bun run esbuild-base --sourcemap --watch",
    "esbuild-base": "node esbuild.js"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}
