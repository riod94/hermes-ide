{
  "name": "hermes-mcp-service",
  "version": "1.0.0",
  "description": "Standalone MCP Service for Hermes IDE — runs as systemd service, independent of code-server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "node esbuild.cjs",
    "build:watch": "node esbuild.cjs --watch",
    "dev": "bun run src/index.ts",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.25"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
