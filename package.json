{
  "name": "hermes-ide-extension",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build:webview": "cd apps/webview-ui && bun run build",
    "build:copy": "rm -rf apps/extension/webview-dist && cp -r apps/webview-ui/dist apps/extension/webview-dist",
    "build:extension": "cd apps/extension && bun run compile",
    "build:mcp": "cd apps/mcp-service && node esbuild.cjs",
    "build": "bun run build:webview && bun run build:copy && bun run build:extension",
    "package": "bun run build && cd apps/extension && bunx @vscode/vsce package --no-dependencies",
    "dev:webview": "cd apps/webview-ui && bun run dev"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
